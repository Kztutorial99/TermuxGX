<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- User Message -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/user_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/user_message_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="48dp"
            app:cardBackgroundColor="@color/accent_blue"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_user_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textColor="@android:color/white"
                android:textSize="15sp"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_user_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@id/user_message_card"
            app:layout_constraintTop_toBottomOf="@id/user_message_card"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- AI Message -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ai_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_ai_avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_ai_logo"
            android:contentDescription="@string/ai_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ai_message_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="48dp"
            app:cardBackgroundColor="@color/background_secondary"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintStart_toEndOf="@id/iv_ai_avatar"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_ai_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>

                <LinearLayout
                    android:id="@+id/termux_command_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_code_block"
                    android:padding="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/termux_command"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_termux_command"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/accent_green"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tv_termux_output_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/output_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_termux_output"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:maxLines="10"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_ai_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/ai_message_card"
            app:layout_constraintTop_toBottomOf="@id/ai_message_card"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- System Message -->
    <TextView
        android:id="@+id/tv_system_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"/>
</LinearLayout>
